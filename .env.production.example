# ── ASIDE Production Environment Variables ─────────────────────
#
# Frontend (Vercel)
# -----------------
# Set these in the Vercel dashboard under Settings > Environment Variables.
#
# WebSocket server URL (deployed on Railway or similar)
VITE_WS_URL=wss://aside-sync.railway.app

# Gemini API key — used by the Vercel serverless function (api/gemini.js).
# On Vercel, set this as GEMINI_API_KEY (without VITE_ prefix) so it stays
# server-side only. The VITE_ prefixed version is only needed for local dev.
GEMINI_API_KEY=AIzaSy...

#
# WebSocket Server (Railway)
# --------------------------
# Railway auto-injects PORT. No extra env vars needed for the sync server.
# PORT=3001  (set automatically by Railway)
