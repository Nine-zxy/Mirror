# ── Anthropic API (required for AI scenario generation) ──────────
# Without this, the system uses a built-in fallback script.
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ── Firebase (required for two-device sync) ───────────────────────
# Without these, the system uses localStorage (single-device demo mode).
# Create a project at https://console.firebase.google.com/
# Enable Firestore Database (in test mode for development)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
