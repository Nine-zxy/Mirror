# ── Mirror Demo — Environment Variables ──────────────────────
#
# Copy this file to .env.local and fill in your API key.
# The key is used server-side by Vite's proxy — it is NEVER
# included in the browser bundle.
#
# Without this key, Mirror falls back to an intelligent
# template-based scenario using extracted names & context.

VITE_ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
